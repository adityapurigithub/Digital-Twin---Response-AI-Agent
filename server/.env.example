# =============================================
# AutoPilot AI — Server Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- App Config ---
PORT=3001
CLIENT_URL=http://localhost:5174

# --- AI Settings ---
# Messages with confidence score below this value go to Review Queue (0-100)
CONFIDENCE_THRESHOLD=85

# --- Your WhatsApp number (the one you'll receive messages on) ---
YOUR_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX
